{
  "name": "@majordomo/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun src/server.ts",
    "build": "bun run build:client && bun build src/server.ts --outdir dist",
    "build:client": "bun build src/app.tsx --outdir dist/ --minify --sourcemap=none && cp src/index.html dist/index.html",
    "dev:client": "bun build src/app.tsx --outdir dist/ --watch"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "hono": "^4.12.12",
    "imapflow": "^1.3.1",
    "js-yaml": "^4.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^6.0.2"
  }
}

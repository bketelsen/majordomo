# Majordomo environment configuration
# Copy to .env and customize

# ── Web service ───────────────────────────────────────────────────────────────
# Port for web dashboard
# Default: 3000
PORT=3000

# ── State directories ─────────────────────────────────────────────────────────
# State home: sessions, DBs, scratch, widgets
# Default: ~/.majordomo
MAJORDOMO_STATE=~/.majordomo

# Deploy home: deployed artifacts (used by bin/majordomo)
# Default: ~/.local/share/majordomo
MAJORDOMO_HOME=~/.local/share/majordomo

# Override project root (rarely needed)
# Default: auto-detected
# MAJORDOMO_PROJECT_ROOT=/path/to/sionapi

# ── Telegram ──────────────────────────────────────────────────────────────────
# Bot token from @BotFather (optional)
# Required only if using Telegram integration
TELEGRAM_BOT_TOKEN=

# ── LLM API keys ──────────────────────────────────────────────────────────────
# GitHub Copilot (recommended): run `pi` → /login → GitHub Copilot
# No API key needed if using GitHub Copilot subscription
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Pi binary ─────────────────────────────────────────────────────────────────
# Path to pi binary if not on PATH (optional)
# PI_BIN=/usr/local/bin/pi

# ── Email widget (optional) ───────────────────────────────────────────────────
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993
# IMAP_USER=you@gmail.com
# IMAP_PASSWORD=app-specific-password
# IMAP_MAILBOX=INBOX
# IMAP_COUNT=10
